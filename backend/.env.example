# 复制为 .env 并填入真实值；.env 不要提交到 git。
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-haiku-4-5-20251001

# 生产部署后填你的客户端来源；本地开发可留默认。上线可先用 *
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,exp://*

# 访问令牌：客户端 app.json extra.appToken 必须与此一致。生产务必改成长随机串：
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
APP_TOKEN=

# 每个 IP 在 RATE_LIMIT_WINDOW 秒内最多 RATE_LIMIT_MAX 次 /api 请求
RATE_LIMIT_MAX=30
RATE_LIMIT_WINDOW=60

LOG_LEVEL=INFO
