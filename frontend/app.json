{
  "expo": {
    "name": "BookMirror",
    "slug": "bookmirror",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bookmirror.app",
      "infoPlist": {
        "LSApplicationQueriesSchemes": [
          "weread",
          "snssdk1112",
          "qqreader",
          "openapp.jdmobile",
          "taobao",
          "dangdang",
          "com.amazon.mobile.shopping",
          "douban",
          "weread",
          "snssdk1112",
          "qqreader",
          "openapp.jdmobile",
          "taobao",
          "dangdang",
          "com.amazon.mobile.shopping",
          "douban",
          "weread",
          "snssdk1112",
          "qqreader",
          "openapp.jdmobile",
          "taobao",
          "dangdang",
          "com.amazon.mobile.shopping",
          "douban",
          "weread",
          "snssdk1112",
          "qqreader",
          "openapp.jdmobile",
          "taobao",
          "dangdang",
          "com.amazon.mobile.shopping",
          "douban"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bookmirror.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF7F2"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "extra": {
      "apiBaseUrl": "https://bookmirror-api.onrender.com",
      "appToken": "Xj8XJ6kBPuWufufJRg20gawlcRcR9bF0QNCj3xim7Jw",
      "google": {
        "webClientId": "496633672820-bkpvm6vltms05g9207vqvhl8dkijqfqo.apps.googleusercontent.com",
        "iosClientId": "496633672820-5s0q742nfo2acnjfbn6rgtsj3t3d9l1u.apps.googleusercontent.com"
      },
      "eas": {
        "projectId": "8cc1c5c4-820b-4ae6-a018-3d79dd20d52c"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "允许 BookMirror 访问相册，用于设置头像和给雪宝发图片。",
          "cameraPermission": "允许 BookMirror 使用相机，用于拍照发给雪宝。"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.496633672820-5s0q742nfo2acnjfbn6rgtsj3t3d9l1u"
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "允许 BookMirror 使用麦克风，用于语音和雪宝聊天。",
          "speechRecognitionPermission": "允许 BookMirror 使用语音识别，把你说的话转成文字。"
        }
      ]
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/8cc1c5c4-820b-4ae6-a018-3d79dd20d52c"
    }
  }
}
